{
  "manifest_version": 3,
  "name": "Guardian Network Monitor",
  "version": "1.0",
  "description": "Sends visited URLs to the Guardian parental control server.",
  "permissions": ["tabs", "storage", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Guardian Monitor"
  }
}
